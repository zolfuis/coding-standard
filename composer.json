{
    "name": "zolfuis/coding-standard",
    "description": "PHP coding standard ruleset based on PSR-12 and Slevomat Coding Standard",
    "type": "phpcodesniffer-standard",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs --standard=phpcs.xml --extensions=php",
        "phpcbf": "vendor/bin/phpcbf --standard=phpcs.xml --extensions=php"
    }
}
